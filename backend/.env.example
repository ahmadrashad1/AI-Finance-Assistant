# Copy this file to .env and adjust values for your local environment.

# PostgreSQL connection string (async driver). Matches the `postgres` service
# in the repo-root docker-compose.yml by default.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_employee_platform

# LLM provider configuration. Not used yet (Milestone 1 is infrastructure only)
# but wired up now so later milestones don't need a config redesign.
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of origins allowed to call this API (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000
