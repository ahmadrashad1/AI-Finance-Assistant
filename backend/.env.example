# Copy this file to .env and adjust values for your local environment.

# PostgreSQL connection string (async driver). Matches the `postgres` service
# in the repo-root docker-compose.yml by default.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_employee_platform

# LLM provider configuration. Using Groq for now since it's free during
# pre-revenue development; the LLMService protocol makes this a one-line
# swap back to Anthropic (LLM_PROVIDER=anthropic, LLM_MODEL=claude-haiku-4-5)
# whenever that's warranted.
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of origins allowed to call this API (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Simulated 'today' for all time-dependent business logic (ISO date). Defaults to 2026-07-08.
# SIMULATION_TODAY=2026-07-08
